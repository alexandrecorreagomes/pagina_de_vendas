# ==============================================================
#  .env.example — Página de Vendas
# ==============================================================
#
#  INSTRUÇÕES:
#  1. Copie este arquivo para ".env" (git ignorará o .env real)
#     > cp .env.example .env   (Linux/Mac)
#     > copy .env.example .env  (Windows)
#
#  2. Preencha os valores reais no seu .env local.
#  3. NUNCA faça commit do arquivo .env com dados reais!
#
#  PADRÃO VITE: Variáveis devem começar com VITE_ para serem
#  acessíveis no código via import.meta.env.VITE_NOME_VAR
# ==============================================================

# ── Ambiente ───────────────────────────────────────────────────
# Valores possíveis: development | staging | production
NODE_ENV=development

# ── URL base da API (se aplicável no futuro) ──────────────────
# VITE_API_URL=https://api.seudominio.com.br

# ── Chave pública de analytics (ex.: Google Analytics 4) ──────
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Chave pública de pixel de conversão (ex.: Meta/Facebook) ──
# VITE_FB_PIXEL_ID=XXXXXXXXXXXXXXXXX

# ── URL do webhook de formulário (ex.: Formspree, Getform) ────
# VITE_FORM_ENDPOINT=https://formspree.io/f/XXXXXXX
