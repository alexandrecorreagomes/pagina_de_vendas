# ============================================================
#  .gitattributes — Normalização de line endings
# ============================================================
#
#  Garante que o repositório use LF (Unix-style) para todos os
#  arquivos de texto, independentemente do SO do desenvolvedor.
#  Referência: https://git-scm.com/docs/gitattributes
# ============================================================

# Comportamento padrão: normaliza todos os arquivos de texto para LF
* text=auto eol=lf

# Arquivos binários — nunca converter
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.svg  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tar  binary
